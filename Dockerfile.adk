# =============================================================================
# Dockerfile.adk — Google ADK com agente ANEEL RAG
# Sem GPU — consome embedding via HTTP e GAIA via OpenAI-compat
# =============================================================================
FROM python:3.11-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    "google-adk==0.5.0" \
    "litellm>=1.40.0" \
    openai \
    "qdrant-client>=1.9.0" \
    requests \
    python-dotenv \
    deprecated

WORKDIR /app

RUN mkdir -p aneel_rag
COPY scripts/agent.py aneel_rag/
COPY scripts/rag_tools.py aneel_rag/
COPY scripts/migrate_qdrant.py aneel_rag/
RUN echo "from . import agent" > aneel_rag/__init__.py

EXPOSE 8081

CMD ["adk", "web", "--port", "8081"]
