# =============================================================================
# Dockerfile.adk — Google ADK com agente ANEEL RAG
# Sem GPU — consome embedding via HTTP e GAIA via OpenAI-compat
# =============================================================================
FROM python:3.11-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    "google-adk==0.5.0" \
    "litellm>=1.40.0" \
    openai \
    "qdrant-client>=1.9.0" \
    requests \
    python-dotenv

WORKDIR /app

# Scripts do agente
COPY scripts/agent.py .
COPY scripts/rag_tools.py .
COPY scripts/migrate_qdrant.py .

EXPOSE 8081

CMD ["adk", "web", "--host", "0.0.0.0", "--port", "8081"]
