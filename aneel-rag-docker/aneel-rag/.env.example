# =============================================================================
# ANEEL RAG — Variáveis de ambiente
# Copie para .env e preencha os campos marcados com <- PREENCHER
# GAIA roda 100% local via vLLM — sem necessidade de chave de API externa
# =============================================================================

# ── Qdrant LOCAL (Docker) ─────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_APIKEY=                   # vazio = sem autenticação (instância local)
QDRANT_COLLECTION=aneel_rag

# ── Qdrant CLOUD (somente para migração) ──────────────────────────────────────
# Preencha antes de rodar: python3 migrate_qdrant.py
# Pode remover após a migração.
QDRANT_CLOUD_URL=        # <- PREENCHER p/ migração: https://xxxx.cloud.qdrant.io
QDRANT_CLOUD_APIKEY=     # <- PREENCHER p/ migração

# ── GAIA vLLM (Docker interno — não alterar) ──────────────────────────────────
GAIA_API_URL=http://gaia:8080/v1
MODEL_NAME=gaia-4b
MODEL_PATH=/models/gaia-4b

# ── Embedding (Docker interno — não alterar) ───────────────────────────────────
EMBEDDING_URL=http://embedding:8082
BGE_MODEL_PATH=BAAI/bge-m3

# ── GPU (L4 · 24GB VRAM) ──────────────────────────────────────────────────────
# gaia:      GPU_MEMORY_UTILIZATION=0.70 → ~16.8GB (controlado pelo vLLM)
# embedding: torch.cuda.set_per_process_memory_fraction(0.25) → ~6GB (no código)
# livre:     ~1.2GB (~5%)
GPU_MEMORY_UTILIZATION=0.70
MAX_MODEL_LEN=8192
DTYPE=bfloat16
