# =============================================================================
# Dockerfile.gaia — vLLM servindo CEIA-UFG/Gemma-3-Gaia-PT-BR-4b-it
# GPU: NVIDIA L4 · bfloat16 · 70% VRAM (~16.8GB)
# =============================================================================
FROM nvidia/cuda:12.1.1-cudnn8-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive

# Dependências de sistema
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip git curl wget \
    && rm -rf /var/lib/apt/lists/*

# Instalar vLLM e dependências
RUN pip3 install --no-cache-dir \
    "vllm>=0.4.3,<0.7" \
    huggingface_hub \
    transformers \
    accelerate \
    python-dotenv

WORKDIR /app
COPY scripts/serve_gaia.py .

# Variáveis padrão (sobrescritas pelo docker-compose)
ENV MODEL_PATH=/models/gaia-4b \
    MODEL_NAME=gaia-4b \
    HOST=0.0.0.0 \
    PORT=8080 \
    GPU_MEMORY_UTILIZATION=0.70 \
    MAX_MODEL_LEN=8192 \
    DTYPE=bfloat16

EXPOSE 8080

CMD ["python3", "serve_gaia.py"]
